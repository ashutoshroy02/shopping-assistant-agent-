# Application
APP_NAME=Shopping Assistant
APP_ENV=development
DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (Docker handles this)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shopping_assistant
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/shopping_assistant

# Redis (Docker handles this)
REDIS_URL=redis://redis:6379/0

# ChromaDB (Docker handles this)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# LLM - Groq (Free API - https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
